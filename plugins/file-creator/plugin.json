{
  "id": "file-creator",
  "name": "File Creator",
  "version": "2.0.0",
  "stateVersion": 2,
  "type": "button",
  "keywords": ["files", "create"],
  "description": "Create files with custom extensions.",
  "state": {
    "initial": {
      "fileName": "",
      "fileExtension": "txt",
      "savedExtensions": ["txt", "json"]
    }
  },
  "lifecycle": {
    "onMount": [
      ["local", "actions/renderExtensions"]
    ]
  },
  "ui": {
    "layout": "container",
    "children": [
      {
        "type": "header",
        "title": "File Creator",
        "subtitle": "Create files with custom extensions"
      },
      {
        "type": "row",
        "children": [
          {
            "type": "input",
            "slot": "fileName",
            "placeholder": "File name",
            "flex": 1
          },
          {
            "type": "input",
            "slot": "fileExtension",
            "placeholder": "Extension",
            "flex": 1
          }
        ]
      },
      {
        "type": "row",
        "children": [
          {
            "type": "button",
            "text": "Add Extension",
            "variant": "secondary",
            "onClick": ["local", "actions/addExtension"]
          },
          {
            "type": "button",
            "text": "Create File",
            "variant": "primary",
            "onClick": ["local", "actions/createFile"]
          }
        ]
      },
      {
        "type": "card-list",
        "slot": "extensions",
        "template": "render/extensionCard",
        "empty": "No extensions saved yet"
      }
    ]
  }
}