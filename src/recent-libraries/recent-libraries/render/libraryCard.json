{
  "type": "card",
  "title": "{{name}}",
  "content": {
    "type": "row",
    "justify": "between",
    "children": [
      {
        "type": "text",
        "value": "{{path}}",
        "class": "text-sm break-all"
      },
      {
        "type": "badge",
        "text": "{{status}}",
        "variant": "{{statusVariant}}"
      }
    ]
  },
  "actions": [
    {
      "text": "Open",
      "variant": "primary",
      "onClick": ["local", "actions/open", ["{{self}}"], {}]
    },
    {
      "text": "Remove",
      "variant": "error",
      "onClick": ["local", "actions/remove", ["{{self}}"], {}]
    }
  ]
}