{
  "type": "card",
  "title": ".{{extension}}",
  "subtitle": "Quick-create a file with this extension",
  "actions": [
    {
      "text": "Create",
      "variant": "primary",
      "onClick": ["local", "actions/createFile", ["{{self}}"], {}]
    },
    {
      "text": "Remove",
      "variant": "error",
      "onClick": ["local", "actions/removeExtension", ["{{self}}"], {}]
    }
  ]
}
